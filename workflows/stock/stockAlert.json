    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.body.events[0].message.text;\n\n// 抓出「連續數字」\nconst match = rawText.match(/\\d+/);\n\n// 如果有找到數字 → 用數字\nconst stockCode = match ? match[0] : rawText;\n\nreturn {\n  \"sessionId\":\"ee30b75b22424f63b258662ecc77f276\",\n  replyToken: $input.first().json.body.events[0].replyToken,\n  stockCode: stockCode,\n  userId: $input.first().json.body.events[0].source.userId,\n  chatInput: $input.first().json.body.events[0].message.text\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        -144
      ],
      "id": "07666635-017e-45bd-b731-d1d1184c0507",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "url": "https://api.finmindtrade.com/api/v4/data?dataset=TaiwanStockPrice",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "data_id",
              "value": "={{ $json.stockCode }}"
            },
            {
              "name": "start_date",
              "value": "={{ $now.minus({ days: 30 }).toISODate() }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
