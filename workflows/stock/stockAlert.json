        "jsCode": "let text = $json.output || \"\";\n\n// 強制轉純文字\ntext = String(text);\n\n// 清洗\ntext = text\n  .replace(/\\$/g, '')\n  .replace(/[#*`]/g, '')\n  .replace(/[\\u0000-\\u001F]/g, '')\n  .replace(/\\n{3,}/g, '\\n\\n') // 避免太多空行\n  .trim();\n\n// 長度限制\ntext = text.slice(0, 4900);\n\nreturn {\n  ...$json,\n  cleanText: text\n};"
